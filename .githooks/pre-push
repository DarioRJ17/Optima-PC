#!/bin/sh
# Hook de pre-push: ejecuta la suite de tests del backend antes de subir a main.
# Si algún test falla, el push se aborta y el commit no llega a producción.
#
# Activación (una sola vez, ya versionado en el repo):
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-push
#
# Para saltarlo puntualmente (no recomendado):  git push --no-verify

echo "▶ Ejecutando los tests del backend antes del push..."

cd "$(git rev-parse --show-toplevel)/backend" || exit 1

if ! ./mvnw -B test; then
  echo "❌ Tests fallidos: push cancelado. Corrige los errores y vuelve a intentarlo."
  exit 1
fi

echo "✅ Tests correctos: continuando con el push."
exit 0
